# ── Process identity ──────────────────────────────────────────────────────────
# UID/GID of the user that runs the Node.js process inside the container.
# Must match the owner of ./data/state on the host so the process can write
# state files. Run `id -u` / `id -g` to find your host user's values.
# Ensure the host directory has correct ownership before first run:
#   chown -R $UID:$GID ./data/state
UID=1000
GID=1000

# ── Server ───────────────────────────────────────────────────────────────────
# Port the Express server listens on
PORT=3000

# Node environment (production | development)
NODE_ENV=production

# ── Data ─────────────────────────────────────────────────────────────────────
# Path inside the container where CSV files are mounted via volume
# Override if you change the volume mount target in docker-compose.yml
TRANSACTIONS_PATH=/app/data/transactions

# ── State Persistence ─────────────────────────────────────────────────────────
# Path where JSON state files are stored (categories, exclusions, rules, etc.)
# Must be writable. Mount as a Docker volume to persist across restarts.
STATE_PATH=/app/data/state

# ── Authentication (optional) ─────────────────────────────────────────────────
# Leave both blank to disable auth entirely.
# Set both to enable HTTP Basic Auth on all routes (requires issue #14).
BASIC_AUTH_USER=
BASIC_AUTH_PASS=

# ── LLM — Azure OpenAI (preferred) ───────────────────────────────────────────
# Azure AI Foundry endpoint. Find it in Foundry → your project → Deployments.
# Format: https://<resource-name>.cognitiveservices.azure.com/
AZURE_OPENAI_ENDPOINT=
# API key from Azure Portal → your OpenAI resource → Keys and Endpoint.
AZURE_OPENAI_API_KEY=
# The deployment name you created in Azure AI Foundry (e.g. gpt-4o-mini).
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
# API version. 2025-01-01-preview supports gpt-4o-mini and all features used here.
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# ── LLM — OpenAI direct (alternative to Azure) ───────────────────────────────
# Used when AZURE_OPENAI_ENDPOINT / AZURE_OPENAI_API_KEY are not set.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ── LangSmith Observability (optional) ───────────────────────────────────────
# LangSmith is an optional debugging/tracing platform by LangChain.
# Sign up at https://smith.langchain.com — free tier available.
# Set LANGSMITH_TRACING=true and add your API key to enable trace logging.
# Leave blank to disable entirely (no effect on functionality).
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=financial-insights

# ── LLM Tuning ────────────────────────────────────────────────────────────────
# Temperature: 0.1 = factual/deterministic, 1.0 = creative. Keep low for finance.
LLM_TEMPERATURE=0.1
# Max tokens per LLM response. 4096 is sufficient for all features.
LLM_MAX_TOKENS=4096

# ── App Config ────────────────────────────────────────────────────────────────
APP_TITLE=Financial Insights

# ── Knowledge Base (issue #53) ────────────────────────────────────────────────
# Path to folder containing local .md / .txt knowledge files.
# These are indexed alongside URL sources configured in the Settings UI.
# Mount as a read-only Docker volume to add documents without rebuilding the image.
KNOWLEDGE_BASE_PATH=data/knowledge

# Embedding model deployment name (Azure OpenAI). Defaults to text-embedding-3-small.
# Only needed if your embeddings deployment has a different name than the default.
# AZURE_OPENAI_EMBEDDINGS_DEPLOYMENT=text-embedding-3-small

# Embedding model name (OpenAI direct). Defaults to text-embedding-3-small.
# OPENAI_EMBEDDINGS_MODEL=text-embedding-3-small

