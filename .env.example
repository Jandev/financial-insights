# ── Process identity ──────────────────────────────────────────────────────────
# UID/GID of the user that runs the Node.js process inside the container.
# Must match the owner of ./data/state on the host so the process can write
# state files. Run `id -u` / `id -g` to find your host user's values.
# Ensure the host directory has correct ownership before first run:
#   chown -R $UID:$GID ./data/state
UID=1000
GID=1000

# ── Server ───────────────────────────────────────────────────────────────────
# Port the Express server listens on
PORT=3000

# Node environment (production | development)
NODE_ENV=production

# ── Data ─────────────────────────────────────────────────────────────────────
# Path inside the container where CSV files are mounted via volume
# Override if you change the volume mount target in docker-compose.yml
TRANSACTIONS_PATH=/app/data/transactions

# ── State Persistence ─────────────────────────────────────────────────────────
# Path where JSON state files are stored (categories, exclusions, rules, etc.)
# Must be writable by the Node.js process. Mount as a Docker volume to persist
# state across container restarts.
# Default (dev):    ./data/state
# Default (Docker): /app/data/state  (set in docker-compose environment block)
STATE_PATH=./data/state

# ── Authentication (optional) ─────────────────────────────────────────────────
# Leave both blank to disable auth entirely.
# Set both to enable HTTP Basic Auth on all routes (requires issue #14).
BASIC_AUTH_USER=
BASIC_AUTH_PASS=

# ── LLM Categorization — OpenAI (future feature, issue #18) ──────────────────
# Used when AI-powered transaction categorization is enabled.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ── LLM Categorization — Azure OpenAI (alternative to OpenAI) ────────────────
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-02-01

# ── App Config ────────────────────────────────────────────────────────────────
APP_TITLE=Financial Insights
